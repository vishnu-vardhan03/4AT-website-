{
  "name": "4at-consulting-backend",
  "version": "1.0.0",
  "private": true,
  "description": "NestJS API for 4AT Consulting website leads",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
